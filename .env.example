# IRS Logics API (Basic Auth)
IRS_LOGICS_PUBLIC_KEY=your_public_key_here
IRS_LOGICS_SECRET_KEY=your_secret_key_here

# GoHighLevel
GHL_API_KEY=your_ghl_api_key_here
GHL_LOCATION_ID=your_location_id_here
GHL_MCP_TOKEN=your_ghl_private_integration_token_here
GHL_MCP_LOCATION_ID=your_location_id_here

# Supabase (Round-Robin State)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Cron (required in production)
CRON_SECRET=your_cron_secret_here

# Gmail — officer notification when IRS Logics task is created (optional)
GMAIL_CLIENT_ID=your_google_oauth_client_id
GMAIL_CLIENT_SECRET=your_google_oauth_client_secret
GMAIL_REFRESH_TOKEN=your_gmail_refresh_token
GMAIL_USER=no-reply@yourdomain.com
# GMAIL_REDIRECT_URI= only needed when generating refresh token locally
# GMAIL_NOTIFY_ENABLED=false  # set to false to disable without removing credentials
# GMAIL_NOTIFY_BCC=no-reply@valortaxrelief.com  # hidden archive copy (set false to disable)
# GMAIL_NOTIFY_MANAGERS=manager1@valortaxrelief.com,manager2@valortaxrelief.com  # Cc on every appointment email
